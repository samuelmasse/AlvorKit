<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    </PropertyGroup>

    <ItemGroup Condition="!Exists('$(BindingsRoot)\AlvorKit.FreeType.Backend\AlvorKit.FreeType.Backend.csproj')">
        <PackageReference Include="AlvorKit.FreeType.Backend" Version="$(FtBindVer)" />
    </ItemGroup>

    <ItemGroup Condition="Exists('$(BindingsRoot)\AlvorKit.FreeType.Backend\AlvorKit.FreeType.Backend.csproj')">
        <ProjectReference Include="$(BindingsRoot)\AlvorKit.FreeType.Backend\AlvorKit.FreeType.Backend.csproj" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\AlvorKit.Graphics2D\AlvorKit.Graphics2D.csproj" />
        <ProjectReference Include="..\AlvorKit.OpenGL.Layer\AlvorKit.OpenGL.Layer.csproj" />
    </ItemGroup>

    <ItemGroup>
        <Using Include="AlvorKit.FreeType" />
        <Using Include="AlvorKit.OpenGL" />
        <Using Include="AlvorKit.Graphics2D" />
        <Using Include="AlvorKit.OpenGL.Layer" />
        <InternalsVisibleTo Include="AlvorKit.Graphics2D.Fonts.Test" />
    </ItemGroup>

</Project>
