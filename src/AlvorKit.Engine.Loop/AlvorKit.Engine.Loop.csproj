<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <AllowUnsafeBlocks>True</AllowUnsafeBlocks>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Tomlyn" Version="0.19.0" />
        <PackageReference Include="ZString" Version="2.6.0" />
    </ItemGroup>

    <ItemGroup Condition="!Exists('$(BindingsRoot)\AlvorKit.GLFW.Backend\AlvorKit.GLFW.Backend.csproj')">
        <PackageReference Include="AlvorKit.GLFW.Backend" Version="$(GlfwBindVer)" />
    </ItemGroup>

    <ItemGroup Condition="!Exists('$(BindingsRoot)\AlvorKit.OpenGL.Backend\AlvorKit.OpenGL.Backend.csproj')">
        <PackageReference Include="AlvorKit.OpenGL.Backend" Version="$(GlBindVer)" />
    </ItemGroup>

    <ItemGroup Condition="Exists('$(BindingsRoot)\AlvorKit.GLFW.Backend\AlvorKit.GLFW.Backend.csproj')">
        <ProjectReference Include="$(BindingsRoot)\AlvorKit.GLFW.Backend\AlvorKit.GLFW.Backend.csproj" />
    </ItemGroup>

    <ItemGroup Condition="Exists('$(BindingsRoot)\AlvorKit.OpenGL.Backend\AlvorKit.OpenGL.Backend.csproj')">
        <ProjectReference Include="$(BindingsRoot)\AlvorKit.OpenGL.Backend\AlvorKit.OpenGL.Backend.csproj" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\AlvorKit.Engine\AlvorKit.Engine.csproj" />
        <ProjectReference Include="..\AlvorKit.Graphics2D\AlvorKit.Graphics2D.csproj" />
        <ProjectReference Include="..\AlvorKit.Graphics2D.Fonts\AlvorKit.Graphics2D.Fonts.csproj" />
        <ProjectReference Include="..\AlvorKit.Injection\AlvorKit.Injection.csproj" />
        <ProjectReference Include="..\AlvorKit.Maths\AlvorKit.Maths.csproj" />
        <ProjectReference Include="..\AlvorKit.OpenGL.Layer\AlvorKit.OpenGL.Layer.csproj" />
        <ProjectReference Include="..\AlvorKit.Windowing\AlvorKit.Windowing.csproj" />
        <ProjectReference Include="..\AlvorKit.Windowing.Agent\AlvorKit.Windowing.Agent.csproj" />
    </ItemGroup>

    <ItemGroup>
        <EmbeddedResource Include="..\..\res\fonts\RobotoMono-Regular.ttf">
            <LogicalName>AlvorKit.Engine.Loop.res.fonts.RobotoMono-Regular.ttf</LogicalName>
        </EmbeddedResource>
    </ItemGroup>

    <ItemGroup>
        <Using Include="AlvorKit.Engine" />
        <Using Include="AlvorKit.Graphics2D" />
        <Using Include="AlvorKit.Graphics2D.Fonts" />
        <Using Include="AlvorKit.GLFW" />
        <Using Include="AlvorKit.Injection" />
        <Using Include="AlvorKit.Maths" />
        <Using Include="AlvorKit.OpenGL" />
        <Using Include="AlvorKit.OpenGL.Layer" />
        <Using Include="AlvorKit.Windowing" />
        <Using Include="Cysharp.Text" />
        <Using Include="System.Globalization" />
        <Using Include="System.Runtime" />
        <Using Include="Tomlyn" />
        <InternalsVisibleTo Include="AlvorKit.Engine.Test" />
    </ItemGroup>

</Project>
