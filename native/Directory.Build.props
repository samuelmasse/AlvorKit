<Project>
    <PropertyGroup>
        <!-- Version = upstream version/TAG, plus version/REVISION as a 4th segment when non-empty:
             a packaging revision of the same upstream because NuGet versions are immutable. -->
        <Version>$([System.IO.File]::ReadAllText('$(MSBuildProjectDirectory)/version/TAG').Trim())</Version>
        <NativeRevision Condition="Exists('$(MSBuildProjectDirectory)/version/REVISION')">
            $([System.IO.File]::ReadAllText('$(MSBuildProjectDirectory)/version/REVISION').Trim())</NativeRevision>
        <Version Condition="'$(NativeRevision)' != ''">$(Version).$(NativeRevision)</Version>
        <TargetFramework>netstandard2.0</TargetFramework>
        <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <RepositoryType>git</RepositoryType>
    </PropertyGroup>

    <PropertyGroup>
        <BaseOutputPath>..\..\bin\$(MSBuildProjectName)</BaseOutputPath>
        <BaseIntermediateOutputPath>..\..\obj\$(MSBuildProjectName)</BaseIntermediateOutputPath>
        <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    </PropertyGroup>
</Project>
