{
    "kind": "cmake",
    "windows": {
        "cmakeOutput": "freetype.dll",
        "cmakeOptions": [
            "-DBUILD_SHARED_LIBS=ON",
            "-DFT_DISABLE_ZLIB=ON",
            "-DFT_DISABLE_BZIP2=ON",
            "-DFT_DISABLE_PNG=ON",
            "-DFT_DISABLE_HARFBUZZ=ON",
            "-DFT_DISABLE_BROTLI=ON"
        ]
    },
    "linux": {
        "packages": [
            "build-essential",
            "cmake"
        ],
        "armPackages": [
            "gcc-arm-linux-gnueabihf"
        ],
        "cmakeOutput": "libfreetype.so",
        "cmakeOptions": [
            "-DBUILD_SHARED_LIBS=ON",
            "-DFT_DISABLE_ZLIB=ON",
            "-DFT_DISABLE_BZIP2=ON",
            "-DFT_DISABLE_PNG=ON",
            "-DFT_DISABLE_HARFBUZZ=ON",
            "-DFT_DISABLE_BROTLI=ON"
        ],
        "allowedDependencies": [
            "libc.so.6",
            "libm.so.6"
        ]
    },
    "macos": {
        "cmakeOutput": "libfreetype.dylib",
        "cmakeOptions": [
            "-DBUILD_SHARED_LIBS=ON",
            "-DFT_DISABLE_ZLIB=ON",
            "-DFT_DISABLE_BZIP2=ON",
            "-DFT_DISABLE_PNG=ON",
            "-DFT_DISABLE_HARFBUZZ=ON",
            "-DFT_DISABLE_BROTLI=ON"
        ]
    }
}
