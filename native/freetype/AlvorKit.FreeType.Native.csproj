<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <Version>$([System.IO.File]::ReadAllText('$(MSBuildProjectDirectory)/TAG').Trim())</Version>
        <TargetFramework>netstandard2.0</TargetFramework>
        <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageLicenseExpression>FTL OR GPL-2.0-or-later</PackageLicenseExpression>
        <Description>FreeType $(Version) binaries for win-x64, linux-x64 and osx-arm64</Description>
        <RepositoryType>git</RepositoryType>
        <RepositoryUrl>https://gitlab.freedesktop.org/freetype/freetype</RepositoryUrl>
    </PropertyGroup>

    <ItemGroup>
        <None Include="README.md" Pack="true" PackagePath="\" />
        <Content Include="runtimes\**" PackagePath="runtimes" Visible="false" />
    </ItemGroup>

    <Target Name="EnsureNativeBinaries" BeforeTargets="GenerateNuspec">
        <Error Condition="'@(Content)' == ''"
            Text="runtimes/ is empty — build the native binaries first (native/freetype/scripts/)." />
    </Target>

</Project>
