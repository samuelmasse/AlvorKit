{
  "namespace": "AlvorKit.FreeType",
  "apiClass": "Ft",
  "apiSummary": "The FreeType font rendering library: faces, glyph loading and rasterization.",
  "backendClass": "FtBackend",
  "nativeClass": "FtNative",
