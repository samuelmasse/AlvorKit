            "bottom"
        ],
        "glfwGetWindowContentScale": [
            "xscale",
            "yscale"
        ],
        "glfwGetCursorPos": [
            "xpos",
            "ypos"
        ],
        "glfwGetMonitorPos": [
            "xpos",
            "ypos"
        ],
        "glfwGetMonitorWorkarea": [
            "xpos",
