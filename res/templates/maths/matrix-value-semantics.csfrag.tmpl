    /// <summary>Attempts to read the parenthesized matrix body.</summary>
    private static bool TryReadMatrixBody(ReadOnlySpan<char> source, out ReadOnlySpan<char> body)
    {
        source = source.Trim();
        if (source.Length < 2 || source[0] != '(' || source[^1] != ')')
        {
            body = default;
            return false;
        }

        body = source[1..^1].Trim();
        return true;
    }

    /// <summary>Attempts to read the parenthesized UTF-8 matrix body.</summary>
    private static bool TryReadMatrixBody(ReadOnlySpan<byte> source, out ReadOnlySpan<byte> body)
    {
        source = TrimAsciiWhitespace(source);
        if (source.Length < 2 || source[0] != (byte)'(' || source[^1] != (byte)')')
        {
            body = default;
            return false;
        }

        body = TrimAsciiWhitespace(source[1..^1]);
        return true;
    }

    /// <summary>Attempts to parse one column vector before the next matrix separator.</summary>
    private static bool TryReadColumn(
        ref ReadOnlySpan<char> source,
        IFormatProvider? formatProvider,
        out {{ColumnType}} value)
    {
        value = default;
        var separator = FindColumnSeparator(source);
        if (separator < 0 || !TryParseColumn(source[..separator].Trim(), formatProvider, out value))
            return false;

        source = source[(separator + 1)..].TrimStart();
        return true;
    }

    /// <summary>Attempts to parse one UTF-8 column vector before the next matrix separator.</summary>
    private static bool TryReadUtf8Column(
        ref ReadOnlySpan<byte> source,
        IFormatProvider? formatProvider,
        out {{ColumnType}} value)
    {
        value = default;
        var separator = FindColumnSeparator(source);
        if (separator < 0 || !TryParseUtf8Column(TrimAsciiWhitespace(source[..separator]), formatProvider, out value))
            return false;

        source = TrimStartAsciiWhitespace(source[(separator + 1)..]);
        return true;
    }

    /// <summary>Finds the next comma-space separator between nested column vectors.</summary>
    private static int FindColumnSeparator(ReadOnlySpan<char> source)
    {
        var depth = 0;
        for (var index = 0; index < source.Length - 1; index++)
        {
            if (source[index] == '(')
                depth++;
            else if (source[index] == ')')
                depth--;
            else if (depth == 0 && source[index] == ',' && char.IsWhiteSpace(source[index + 1]))
                return index;
        }

        return -1;
    }

    /// <summary>Finds the next UTF-8 comma-space separator between nested column vectors.</summary>
    private static int FindColumnSeparator(ReadOnlySpan<byte> source)
    {
        var depth = 0;
        for (var index = 0; index < source.Length - 1; index++)
        {
            if (source[index] == (byte)'(')
                depth++;
            else if (source[index] == (byte)')')
                depth--;
            else if (depth == 0 && source[index] == (byte)',' && IsAsciiWhitespace(source[index + 1]))
                return index;
        }

        return -1;
    }

