    /// <summary>Attempts to append literal text to the destination span.</summary>
    private static bool TryAppend(ReadOnlySpan<char> value, ref Span<char> destination, ref int charsWritten)
    {
        if (!value.TryCopyTo(destination))
            return false;

        destination = destination[value.Length..];
        charsWritten += value.Length;
        return true;
    }

    /// <summary>Attempts to append literal UTF-8 text to the destination span.</summary>
    private static bool TryAppendUtf8(ReadOnlySpan<byte> value, ref Span<byte> destination, ref int bytesWritten)
    {
        if (!value.TryCopyTo(destination))
            return false;

        destination = destination[value.Length..];
        bytesWritten += value.Length;
        return true;
    }

