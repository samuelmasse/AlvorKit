            !{{Plane3Type}}.TryParse(MathsUtf8TextHelper.TrimAsciiWhitespace(body), formatProvider, out var far))
        {
            return false;
        }

        result = new(left, right, bottom, top, near, far);
        return true;
    }

    /// <summary>Returns whether this frustum has the same planes as another frustum.</summary>
    public readonly bool Equals({{TypeName}} other) =>
        Left.Equals(other.Left) &&
        Right.Equals(other.Right) &&
        Bottom.Equals(other.Bottom) &&
        Top.Equals(other.Top) &&
        Near.Equals(other.Near) &&
        Far.Equals(other.Far);

    /// <summary>Returns whether this frustum has the same planes as an object.</summary>
    public override readonly bool Equals(object? obj) =>
        obj is {{TypeName}} other && Equals(other);

    /// <summary>Returns a hash code for this frustum.</summary>
    public override readonly int GetHashCode() =>
        HashCode.Combine(Left, Right, Bottom, Top, Near, Far);

    /// <summary>Creates one plane from a scalar span after validating span length.</summary>
    private static {{Plane3Type}} CreatePlane(ReadOnlySpan<{{ScalarType}}> values, int start)
    {
        if (values.Length < ComponentCount)
            MathsThrowHelper.ThrowSourceSpanTooShort(ComponentCount);

        return new {{Plane3Type}}(values[start..]);
    }

    /// <summary>Returns one plane by zero-based plane index.</summary>
    private readonly {{Plane3Type}} PlaneByIndex(int index) =>
        index switch
        {
            0 => Left,
            1 => Right,
            2 => Bottom,
            3 => Top,
            4 => Near,
            _ => Far,
        };

    /// <summary>Returns whether the plane excludes every point in the box.</summary>
    private static bool PlaneExcludesBox({{Plane3Type}} plane, {{Box3Type}} box) =>
        plane.Evaluate(PositiveVertex(plane, box)) < {{ZeroLiteral}};

    /// <summary>Returns whether the plane contains every point in the box.</summary>
    private static bool PlaneContainsBox({{Plane3Type}} plane, {{Box3Type}} box) =>
        plane.Evaluate(NegativeVertex(plane, box)) >= {{ZeroLiteral}};

    /// <summary>Returns whether a plane does not reject a sphere and updates full-containment state.</summary>
    private static bool PlaneAcceptsSphere({{Plane3Type}} plane, {{Sphere3Type}} sphere, ref bool contains)
    {
        var radiusDistance = sphere.Radius * plane.NormalLength;
        var centerDistance = plane.Evaluate(sphere.Center);
        if (centerDistance < -radiusDistance)
            return false;

        contains &= centerDistance >= radiusDistance;
        return true;
    }

    /// <summary>Returns whether a plane does not reject all corners and updates full-containment state.</summary>
    private static bool PlaneAcceptsCorners({{Plane3Type}} plane, ReadOnlySpan<{{Vector3Type}}> corners, ref bool contains)
    {
        var acceptsAny = false;
        var containsAll = true;
        for (var index = 0; index < corners.Length; index++)
        {
            var distance = plane.Evaluate(corners[index]);
            acceptsAny |= distance >= {{ZeroLiteral}};
            containsAll &= distance >= {{ZeroLiteral}};
        }

        contains &= containsAll;
        return acceptsAny;
    }

    /// <summary>Returns the box vertex farthest along the plane normal.</summary>
    private static {{Vector3Type}} PositiveVertex({{Plane3Type}} plane, {{Box3Type}} box) =>
        new(
            plane.Normal.X >= {{ZeroLiteral}} ? box.Max.X : box.Min.X,
            plane.Normal.Y >= {{ZeroLiteral}} ? box.Max.Y : box.Min.Y,
            plane.Normal.Z >= {{ZeroLiteral}} ? box.Max.Z : box.Min.Z);

    /// <summary>Returns the box vertex farthest against the plane normal.</summary>
    private static {{Vector3Type}} NegativeVertex({{Plane3Type}} plane, {{Box3Type}} box) =>
        new(
            plane.Normal.X >= {{ZeroLiteral}} ? box.Min.X : box.Max.X,
            plane.Normal.Y >= {{ZeroLiteral}} ? box.Min.Y : box.Max.Y,
            plane.Normal.Z >= {{ZeroLiteral}} ? box.Min.Z : box.Max.Z);

    /// <summary>Attempts to find the point shared by three planes.</summary>
    private static bool TryIntersectPlanes({{Plane3Type}} plane0, {{Plane3Type}} plane1, {{Plane3Type}} plane2, out {{Vector3Type}} point)
    {
        var cross12 = {{Vector3Type}}.Cross(plane1.Normal, plane2.Normal);
        var cross20 = {{Vector3Type}}.Cross(plane2.Normal, plane0.Normal);
        var cross01 = {{Vector3Type}}.Cross(plane0.Normal, plane1.Normal);
        var denominator = {{Vector3Type}}.Dot(plane0.Normal, cross12);
        if (denominator == {{ZeroLiteral}})
        {
            point = default;
            return false;
        }

        point = -((cross12 * plane0.Offset) + (cross20 * plane1.Offset) + (cross01 * plane2.Offset)) / denominator;
        return true;
    }

    /// <summary>Attempts to read one non-final plane from a character span.</summary>
    private static bool TryReadPlane(ref ReadOnlySpan<char> body, IFormatProvider? formatProvider, out {{Plane3Type}} plane)
    {
        body = body.Trim();
        var separator = MathsTextSeparatorHelper.FindTopLevelSeparator(body);
        if (separator < 0 || !{{Plane3Type}}.TryParse(body[..separator].Trim(), formatProvider, out plane))
        {
            plane = default;
            return false;
        }

        body = body[(separator + 1)..].Trim();
        return true;
    }

    /// <summary>Attempts to read one non-final plane from a UTF-8 span.</summary>
    private static bool TryReadPlane(ref ReadOnlySpan<byte> body, IFormatProvider? formatProvider, out {{Plane3Type}} plane)
    {
        body = MathsUtf8TextHelper.TrimAsciiWhitespace(body);
        var separator = MathsTextSeparatorHelper.FindTopLevelSeparator(body);
        if (separator < 0 ||
            !{{Plane3Type}}.TryParse(MathsUtf8TextHelper.TrimAsciiWhitespace(body[..separator]), formatProvider, out plane))
        {
            plane = default;
            return false;
        }

        body = MathsUtf8TextHelper.TrimAsciiWhitespace(body[(separator + 1)..]);
        return true;
    }

    /// <summary>Appends all planes to a character destination.</summary>
    private readonly bool AppendFormattedPlanes(
        ref Span<char> destination,
        ref int charsWritten,
        ReadOnlySpan<char> format,
        IFormatProvider? formatProvider) =>
        MathsFormatHelper.TryAppend("(".AsSpan(), ref destination, ref charsWritten) &&
        MathsFormatHelper.TryAppendFormatted(Left, ref destination, ref charsWritten, format, formatProvider) &&
        MathsFormatHelper.TryAppend(", ".AsSpan(), ref destination, ref charsWritten) &&
        MathsFormatHelper.TryAppendFormatted(Right, ref destination, ref charsWritten, format, formatProvider) &&
        MathsFormatHelper.TryAppend(", ".AsSpan(), ref destination, ref charsWritten) &&
        MathsFormatHelper.TryAppendFormatted(Bottom, ref destination, ref charsWritten, format, formatProvider) &&
        MathsFormatHelper.TryAppend(", ".AsSpan(), ref destination, ref charsWritten) &&
        MathsFormatHelper.TryAppendFormatted(Top, ref destination, ref charsWritten, format, formatProvider) &&
        MathsFormatHelper.TryAppend(", ".AsSpan(), ref destination, ref charsWritten) &&
        MathsFormatHelper.TryAppendFormatted(Near, ref destination, ref charsWritten, format, formatProvider) &&
        MathsFormatHelper.TryAppend(", ".AsSpan(), ref destination, ref charsWritten) &&
        MathsFormatHelper.TryAppendFormatted(Far, ref destination, ref charsWritten, format, formatProvider) &&
        MathsFormatHelper.TryAppend(")".AsSpan(), ref destination, ref charsWritten);

    /// <summary>Appends all planes to a UTF-8 destination.</summary>
    private readonly bool AppendFormattedPlanes(
        ref Span<byte> destination,
        ref int bytesWritten,
        ReadOnlySpan<char> format,
        IFormatProvider? formatProvider) =>
        MathsFormatHelper.TryAppend("("u8, ref destination, ref bytesWritten) &&
        MathsFormatHelper.TryAppendFormatted(Left, ref destination, ref bytesWritten, format, formatProvider) &&
        MathsFormatHelper.TryAppend(", "u8, ref destination, ref bytesWritten) &&
        MathsFormatHelper.TryAppendFormatted(Right, ref destination, ref bytesWritten, format, formatProvider) &&
        MathsFormatHelper.TryAppend(", "u8, ref destination, ref bytesWritten) &&
        MathsFormatHelper.TryAppendFormatted(Bottom, ref destination, ref bytesWritten, format, formatProvider) &&
        MathsFormatHelper.TryAppend(", "u8, ref destination, ref bytesWritten) &&
        MathsFormatHelper.TryAppendFormatted(Top, ref destination, ref bytesWritten, format, formatProvider) &&
        MathsFormatHelper.TryAppend(", "u8, ref destination, ref bytesWritten) &&
        MathsFormatHelper.TryAppendFormatted(Near, ref destination, ref bytesWritten, format, formatProvider) &&
        MathsFormatHelper.TryAppend(", "u8, ref destination, ref bytesWritten) &&
        MathsFormatHelper.TryAppendFormatted(Far, ref destination, ref bytesWritten, format, formatProvider) &&
        MathsFormatHelper.TryAppend(")"u8, ref destination, ref bytesWritten);

    /// <summary>Throws when a plane destination span is too short.</summary>
    [DoesNotReturn]
    private static void ThrowPlaneDestinationTooShort() =>
        throw new ArgumentException($"Span must contain at least {PlaneCount} planes.", "destination");

    /// <summary>Throws when a plane source span is too short.</summary>
    [DoesNotReturn]
    private static void ThrowPlaneSourceTooShort() =>
        throw new ArgumentException($"Span must contain at least {PlaneCount} planes.", "planes");

    /// <summary>Throws when a corner destination span is too short.</summary>
    [DoesNotReturn]
    private static void ThrowCornerDestinationTooShort() =>
        throw new ArgumentException($"Span must contain at least {CornerCount} corners.", "destination");
}
