{{TypeHeader}}/// <summary>Owns native secret memory for streaming xxHash3 reset-with-secret APIs.</summary>
/// <remarks>
/// The memory remains valid until this instance is disposed. The allocated size must satisfy xxHash's minimum secret
/// size requirement. A streaming state reset with this secret must be reset again, freed, or no longer used before
/// disposing the secret.
/// </remarks>
public sealed class XxhSecret : IDisposable
{
    /// <summary>Allocates native memory for an xxHash secret.</summary>
    /// <param name="size">Secret size in bytes, at least <see cref="Xxh.Xxh3SecretSizeMin"/>.</param>
    /// <exception cref="ArgumentOutOfRangeException">
    /// <paramref name="size"/> is smaller than <see cref="Xxh.Xxh3SecretSizeMin"/> or too large to expose as a span.
    /// </exception>
    /// <exception cref="OutOfMemoryException">Native allocation failed.</exception>
    public unsafe XxhSecret(nuint size)
    {
        if (size < Xxh.Xxh3SecretSizeMin)
            throw new ArgumentOutOfRangeException(nameof(size), size, $"xxHash secrets must be at least {Xxh.Xxh3SecretSizeMin} bytes.");
        if (size > int.MaxValue)
            throw new ArgumentOutOfRangeException(nameof(size), size, "xxHash secret size must fit in a Span<byte> length.");

        Pointer = (nint)NativeMemory.AllocZeroed(size);
        if (Pointer == 0)
            throw new OutOfMemoryException($"Could not allocate {size} bytes for an xxHash secret.");

        Size = size;
    }

    /// <summary>Pointer to the owned native secret bytes.</summary>
    public nint Pointer { get; private set; }

    /// <summary>Secret size in bytes.</summary>
    public nuint Size { get; private set; }

    /// <summary>Writable byte view over the owned native secret memory.</summary>
    public unsafe Span<byte> Bytes =>
        new((void*)Pointer, checked((int)Size));

    /// <summary>Releases owned native memory if this instance is not disposed explicitly.</summary>
    ~XxhSecret() =>
        Free();

    /// <summary>Releases the owned native secret memory.</summary>
    public void Dispose()
    {
        Free();
        GC.SuppressFinalize(this);
    }

    /// <summary>Frees native memory and marks this instance as empty.</summary>
    private unsafe void Free()
    {
        NativeMemory.Free((void*)Pointer);
        Pointer = 0;
        Size = 0;
    }
}
