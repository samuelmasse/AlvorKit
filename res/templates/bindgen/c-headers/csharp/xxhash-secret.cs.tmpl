{{TypeHeader}}/// <summary>
/// Owns native secret memory for <c>XXH3_64bits_reset_withSecret</c>, <c>XXH3_128bits_reset_withSecret</c>,
/// and related streaming reset APIs.
/// </summary>
/// <remarks>
/// The memory remains valid until this instance is disposed. The allocated size must satisfy
/// <c>XXH3_SECRET_SIZE_MIN</c>. A streaming state reset with this secret must be reset again, freed, or no longer used
/// before disposing the secret.
/// </remarks>
public sealed class XxhSecret : IDisposable
{
    /// <summary>Allocates native memory for a <c>XXH3_SECRET_SIZE_MIN</c>-compatible xxHash secret.</summary>
    /// <param name="size">
    /// Secret size in bytes, at least <see cref="XxhEnum.Xxh3SecretSizeMin"/> from <c>XXH3_SECRET_SIZE_MIN</c>.
    /// </param>
    /// <exception cref="ArgumentOutOfRangeException">
    /// <paramref name="size"/> is smaller than <see cref="XxhEnum.Xxh3SecretSizeMin"/> or too large to expose as a span.
    /// </exception>
    /// <exception cref="OutOfMemoryException">Native allocation failed.</exception>
    public unsafe XxhSecret(nuint size)
    {
        if (size < (nuint)(long)XxhEnum.Xxh3SecretSizeMin)
            throw new ArgumentOutOfRangeException(
                nameof(size),
                size,
                $"xxHash secrets must be at least {(long)XxhEnum.Xxh3SecretSizeMin} bytes.");
        if (size > int.MaxValue)
            throw new ArgumentOutOfRangeException(nameof(size), size, "xxHash secret size must fit in a Span<byte> length.");

        Pointer = (nint)NativeMemory.AllocZeroed(size);
        if (Pointer == 0)
            throw new OutOfMemoryException($"Could not allocate {size} bytes for an xxHash secret.");

        Size = size;
    }

    /// <summary>Pointer passed as native <c>secret</c> data to <c>XXH3_64bits_reset_withSecret</c> and related APIs.</summary>
    public nint Pointer { get; private set; }

    /// <summary>Size in bytes passed as native <c>secretSize</c> to <c>XXH3_64bits_reset_withSecret</c> and related APIs.</summary>
    public nuint Size { get; private set; }

    /// <summary>Writable byte view over memory suitable for <c>XXH3_generateSecret</c> output or custom secret data.</summary>
    public unsafe Span<byte> Bytes =>
        new((void*)Pointer, checked((int)Size));

    /// <summary>Releases native <c>secret</c> memory if this instance is not disposed explicitly.</summary>
    ~XxhSecret() =>
        Free();

    /// <summary>Releases the owned native <c>secret</c> memory.</summary>
    public void Dispose()
    {
        Free();
        GC.SuppressFinalize(this);
    }

    /// <summary>Frees native <c>secret</c> memory and marks this instance as empty.</summary>
    private unsafe void Free()
    {
        NativeMemory.Free((void*)Pointer);
        Pointer = 0;
        Size = 0;
    }
}
