<Project Sdk="Microsoft.NET.Sdk">

    <Import Project="..\..\AlvorKit.Packages.props" />

    <PropertyGroup>
        <AllowUnsafeBlocks>True</AllowUnsafeBlocks>
    </PropertyGroup>

    <ItemGroup Condition="!Exists('$(BindingsRoot)\AlvorKit.NFDe.Backend\AlvorKit.NFDe.Backend.csproj')">
        <PackageReference Include="AlvorKit.NFDe.Backend" Version="$(NfdeBindVer)" />
    </ItemGroup>

    <ItemGroup Condition="Exists('$(BindingsRoot)\AlvorKit.NFDe.Backend\AlvorKit.NFDe.Backend.csproj')">
        <ProjectReference Include="$(BindingsRoot)\AlvorKit.NFDe.Backend\AlvorKit.NFDe.Backend.csproj" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\src\AlvorKit.Maths\AlvorKit.Maths.csproj" />
        <ProjectReference Include="..\..\src\AlvorKit.Windowing.Agent\AlvorKit.Windowing.Agent.csproj" />
        <ProjectReference Include="..\..\src\AlvorKit.Windowing.Glfw\AlvorKit.Windowing.Glfw.csproj" />
        <ProjectReference Include="..\..\src\AlvorKit.Mocking\AlvorKit.Mocking.csproj" />
    </ItemGroup>

    <ItemGroup>
        <Using Include="AlvorKit.Maths" />
        <Using Include="AlvorKit.Mocking" />
        <Using Include="AlvorKit.GLFW" />
        <Using Include="AlvorKit.NFDe" />
        <Using Include="AlvorKit.OpenGL" />
        <Using Include="AlvorKit.OpenGL.Layer" />
        <Using Include="AlvorKit.Windowing" />
        <Using Include="System.Globalization" />
        <Using Include="System.Reflection" />
    </ItemGroup>

</Project>
